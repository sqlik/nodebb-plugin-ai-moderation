{
  "id": "nodebb-plugin-ai-moderation",
  "name": "AI Moderation",
  "description": "Automatic forum moderation powered by OpenRouter. Two-tier model pipeline (triage + escalation) with configurable thresholds, per-category actions, budget caps, and NodeBB flag integration.",
  "url": "https://github.com/sqlik/nodebb-plugin-ai-moderation",
  "library": "./library.js",
  "hooks": [
    { "hook": "static:app.load", "method": "init" },
    { "hook": "filter:admin.header.build", "method": "addAdminMenu" },
    { "hook": "filter:post.create", "method": "onPostCreate" },
    { "hook": "filter:topic.post", "method": "onTopicPost" },
    { "hook": "action:post.save", "method": "onPostSave" },
    { "hook": "action:post.edit", "method": "onPostEdit" }
  ],
  "templates": "public/templates",
  "languages": "languages",
  "modules": {
    "../admin/plugins/ai-moderation.js": "./public/lib/admin.js"
  }
}
